# Server Configuration
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/scouttree
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scouttree
DB_USER=postgres
DB_PASSWORD=password
DB_POOL_MAX=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_PRO_MONTHLY=price_xxx
STRIPE_PRICE_ID_PRO_YEARLY=price_xxx
STRIPE_PRICE_ID_TEAM=price_xxx

# Platform APIs
LICHESS_API_URL=https://lichess.org
LICHESS_CLIENT_ID=your_lichess_client_id
CHESSCOM_API_URL=https://api.chess.com/pub

# Rate Limits
RATE_LIMIT_FREE_REQUESTS_PER_MONTH=3
RATE_LIMIT_PRO_REQUESTS_PER_MONTH=100
RATE_LIMIT_TEAM_REQUESTS_PER_MONTH=500

# Analysis Configuration
STOCKFISH_DEPTH_BLITZ=20
STOCKFISH_DEPTH_RAPID=25
STOCKFISH_DEPTH_CLASSICAL=30
MAX_GAMES_FETCH=500
CACHE_TTL_GAMES=604800
CACHE_TTL_REPORTS=86400

# AWS S3 (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=scouttree-artifacts

# Monitoring
SENTRY_DSN=
PROMETHEUS_PORT=9090

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
